{
    "name": "vsimke/laravel-activecampaign",
    "description": "A Laravel package for the ActiveCampaign API.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Vladimir Simic",
            "email": "vladimir.simic@prodevcon.ch"
        }
    ],
    "require": {
        "php": ">=8.2",
        "guzzlehttp/guzzle": "^7.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "larastan/larastan": "^3.9",
        "rector/rector": "^2.4",
        "driftingly/rector-laravel": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "Vsimke\\ActiveCampaign\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vsimke\\ActiveCampaign\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vsimke\\ActiveCampaign\\ActiveCampaignServiceProvider"
            ],
            "aliases": {
                "ActiveCampaign": "Vsimke\\ActiveCampaign\\Facades\\ActiveCampaign"
            }
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}